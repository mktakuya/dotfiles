{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME\"/.claude/hooks/notify-waiting.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME\"/.claude/hooks/validate-jira-ticket.sh",
            "timeout": 10,
            "statusMessage": "Jiraチケットの内容をチェック中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME\"/.claude/hooks/notify-complete.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "portal@smarthr-claude-plugins": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "smarthr-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "kufu/smarthr-claude-plugins"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
