{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableAlwaysAllow": false
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "mcpServers": {
    "twilog-mcp": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://twilog-mcp.togetter.dev/mcp",
        "--header",
        "Authorization: Bearer ${TWILOG_API_KEY}"
      ]
    }
  },
  "general": {
    "enableNotifications": true
  },
  "ui": {
    "hideWindowTitle": true,
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
    "hideTips": true,
    "hideBanner": true,
    "hideFooter": true,
    "showMemoryUsage": true,
    "showLineNumbers": false
  }
}
